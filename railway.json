{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && npm install && npm run build",
    "startCommand": "cd backend && npm run start:prod",
    "watchPatterns": [
      "/backend/**"
    ]
  },
  "deploy": {
    "healthcheckPath": "/api/ai/available",
    "healthcheckTimeout": 300
  }
}
